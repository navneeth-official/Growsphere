<?xml version="1.0" encoding="utf-8"?>
<!-- Native splash: brand green + circular leaf (matches launcher). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_icon_dark_green" />
        </shape>
    </item>
    <item android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_brand_launcher_fg" />
    </item>
</layer-list>
